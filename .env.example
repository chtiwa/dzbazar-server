# Copy to .env and fill in real values. Never commit .env.

# Postgres connection string
DB_URI="postgresql://user:password@host:5432/dbname"

# Secret used to sign/verify JWT access + refresh tokens
JWT_SECRET="change-me"

# dev | production — gates secure cookie flags and other environment-specific behavior
APP_ENV=dev

# Resend (transactional email)
RESEND_API_KEY=

# Frontend origins allowed by CORS
CLIENT_URL="http://localhost:5173"
CLIENT_URL_V2="http://localhost:5174"
ADMIN_URL="http://localhost:5173"
SUPER_ADMIN_URL="http://localhost:5175"

# Backblaze B2 (S3-compatible) image storage
B2_KEY_ID=
B2_APP_KEY=
B2_BUCKET_NAME=
B2_REGION=
# Optional — custom public CDN domain for served images; falls back to the
# standard B2 URL format if unset
B2_PUBLIC_BASE_URL=

# Redis (caching, rate limiting)
REDIS_URI="redis://default:password@host:port"

# TikTok Conversions API
TIKTOK_PIXEL_ID=
TIKTOK_ACCESS_TOKEN=

# Facebook CAPI test event code — dev/staging only, omit in production
FACEBOOK_TEST_CODE=
